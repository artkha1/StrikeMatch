# Obtain a free MAP Key at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your_map_key_here

# ACLED Research-tier credentials (https://acleddata.com)
ACLED_USERNAME=your_acled_username
ACLED_PASSWORD=your_acled_password
# Free-tier data lag behind real-time (days); update when the lag visibly shifts.
DATA_LAG_DAYS=364

# Databricks Free Edition — fill from your workspace settings.
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_pat
DATABRICKS_VOLUME_PATH=/Volumes/workspace/fire_pipeline/bronze_inbound
DATABRICKS_JOB_ID=your_job_id
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# Optional medallion identifiers (defaults: workspace / fire_pipeline)
FP_CATALOG=workspace
FP_SCHEMA=fire_pipeline

# Airflow connection consumed by DatabricksRunNowOperator (databricks_default).
AIRFLOW_CONN_DATABRICKS_DEFAULT={"conn_type": "databricks", "host": "your-workspace.cloud.databricks.com", "password": "your_databricks_pat"}
