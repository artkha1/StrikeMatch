# Obtain a free MAP Key at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your_map_key_here

# Optional – defaults to the docker-compose DB below
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/satellite_tracking

# Required for spark_pipeline.py (Phase 4). PySpark 4.x needs Java 17+.
# On Windows, installed via: winget install Microsoft.OpenJDK.17
# JAVA_HOME=C:\Program Files\Microsoft\jdk-17.0.19.10-hotspot
