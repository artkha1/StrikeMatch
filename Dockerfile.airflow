FROM apache/airflow:2.9.2-python3.11
USER root
RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*
USER airflow
# Install extra packages under the Airflow 2.9.2 constraint file so pip cannot
# upgrade (or uninstall) any package that Airflow itself depends on.
RUN pip install --no-cache-dir \
    apache-airflow-providers-databricks \
    databricks-sql-connector \
    databricks-sdk \
    pandas \
    pyarrow \
    --constraint "https://raw.githubusercontent.com/apache/airflow/constraints-2.9.2/constraints-3.11.txt"
